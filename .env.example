# openclaw-api-proxy - Environment Variables
# Copy this file to .env and fill in the keys you need.
# All keys are optional. Only configure the services you use.

# Proxy auth token - set this to guard your proxy with a bearer token
# If not set, a random token is generated on startup and printed to logs
# PROXY_AUTH_TOKEN=

# Port (default: 3000)
# PORT=3000

# === API Keys (add only what you need) ===

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Resend (email)
# RESEND_API_KEY=re_...

# SendGrid (email)
# SENDGRID_API_KEY=SG...

# YNAB (budgeting) - OAuth refresh token
# YNAB_REFRESH_TOKEN=
# YNAB_CLIENT_ID=
# YNAB_CLIENT_SECRET=

# OpenRouter
# OPENROUTER_API_KEY=

# GitHub
# GITHUB_TOKEN=ghp_...

# Notion
# NOTION_API_KEY=secret_...

# Airtable
# AIRTABLE_API_KEY=

# Linear
# LINEAR_API_KEY=lin_api_...

# HubSpot
# HUBSPOT_API_KEY=

# Stripe
# STRIPE_SECRET_KEY=sk_...

# Slack
# SLACK_BOT_TOKEN=xoxb-...

# Twilio
# TWILIO_AUTH_TOKEN=

# Cloudflare
# CLOUDFLARE_API_TOKEN=

# QuickBooks OAuth
# QUICKBOOKS_REFRESH_TOKEN=
# QUICKBOOKS_CLIENT_ID=
# QUICKBOOKS_CLIENT_SECRET=

# Gmail OAuth (direct - recommended)
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=
# GMAIL_IMPERSONATE_EMAIL=you@yourdomain.com

# Gmail via Nango (alternative)
# NANGO_SECRET_KEY=
# NANGO_CONNECTION_ID=
# NANGO_PROVIDER_CONFIG_KEY=google

# Google Service Account (for domain-wide delegation)
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# Safaricom Daraja (M-Pesa)
# DARAJA_ACCESS_TOKEN=
