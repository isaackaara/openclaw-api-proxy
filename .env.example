# openclaw-api-proxy environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

PORT=3000

# Optional: set a bearer token so only authorized agents can call the proxy
# Leave blank to run without auth guard (only do this on a private network)
PROXY_AUTH_TOKEN=

# --- API Keys (one per service) ---
# The proxy reads these at runtime and injects them into forwarded requests.
# Agents never see these values.

RESEND_API_KEY=
YNAB_API_KEY=
OPENROUTER_API_KEY=
GITHUB_TOKEN=
CLOUDFLARE_API_TOKEN=
DARAJA_ACCESS_TOKEN=
GOOGLE_API_KEY=
STRIPE_SECRET_KEY=
SLACK_BOT_TOKEN=
TWILIO_AUTH_TOKEN=
