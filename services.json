{
  "openai": {
    "baseUrl": "https://api.openai.com",
    "keyEnv": "OPENAI_API_KEY",
    "authHeader": "Authorization",
    "authPrefix": "Bearer"
  },
  "anthropic": {
    "baseUrl": "https://api.anthropic.com",
    "keyEnv": "ANTHROPIC_API_KEY",
    "authHeader": "x-api-key",
    "authPrefix": ""
  },
  "resend": {
    "baseUrl": "https://api.resend.com",
    "keyEnv": "RESEND_API_KEY",
    "authHeader": "Authorization",
    "authPrefix": "Bearer"
  },
  "sendgrid": {
    "baseUrl": "https://api.sendgrid.com",
    "keyEnv": "SENDGRID_API_KEY",
    "authHeader": "Authorization",
    "authPrefix": "Bearer"
  },
  "ynab": {
    "baseUrl": "https://api.ynab.com",
    "keyEnv": "YNAB_REFRESH_TOKEN",
    "authHeader": "Authorization",
    "authPrefix": "Bearer",
    "oauth": {
      "clientIdEnv": "YNAB_CLIENT_ID",
      "clientSecretEnv": "YNAB_CLIENT_SECRET",
      "tokenUrl": "https://app.youneedabudget.com/oauth/token",
      "grantType": "refresh_token"
    }
  },
  "openrouter": {
    "baseUrl": "https://openrouter.ai/api",
    "keyEnv": "OPENROUTER_API_KEY",
    "authHeader": "Authorization",
    "authPrefix": "Bearer"
  },
  "github": {
    "baseUrl": "https://api.github.com",
    "keyEnv": "GITHUB_TOKEN",
    "authHeader": "Authorization",
    "authPrefix": "Bearer"
  },
  "notion": {
    "baseUrl": "https://api.notion.com",
    "keyEnv": "NOTION_API_KEY",
    "authHeader": "Authorization",
    "authPrefix": "Bearer"
  },
  "airtable": {
    "baseUrl": "https://api.airtable.com",
    "keyEnv": "AIRTABLE_API_KEY",
    "authHeader": "Authorization",
    "authPrefix": "Bearer"
  },
  "linear": {
    "baseUrl": "https://api.linear.app",
    "keyEnv": "LINEAR_API_KEY",
    "authHeader": "Authorization",
    "authPrefix": "Bearer"
  },
  "hubspot": {
    "baseUrl": "https://api.hubapi.com",
    "keyEnv": "HUBSPOT_API_KEY",
    "authHeader": "Authorization",
    "authPrefix": "Bearer"
  },
  "cloudflare": {
    "baseUrl": "https://api.cloudflare.com/client/v4",
    "keyEnv": "CLOUDFLARE_API_TOKEN",
    "authHeader": "Authorization",
    "authPrefix": "Bearer"
  },
  "safaricom-daraja": {
    "baseUrl": "https://api.safaricom.co.ke",
    "keyEnv": "DARAJA_ACCESS_TOKEN",
    "authHeader": "Authorization",
    "authPrefix": "Bearer"
  },
  "stripe": {
    "baseUrl": "https://api.stripe.com",
    "keyEnv": "STRIPE_SECRET_KEY",
    "authHeader": "Authorization",
    "authPrefix": "Bearer"
  },
  "slack": {
    "baseUrl": "https://slack.com/api",
    "keyEnv": "SLACK_BOT_TOKEN",
    "authHeader": "Authorization",
    "authPrefix": "Bearer"
  },
  "twilio": {
    "baseUrl": "https://api.twilio.com",
    "keyEnv": "TWILIO_AUTH_TOKEN",
    "authHeader": "Authorization",
    "authPrefix": "Bearer"
  },
  "quickbooks": {
    "baseUrl": "https://quickbooks.api.intuit.com",
    "keyEnv": "QUICKBOOKS_REFRESH_TOKEN",
    "authHeader": "Authorization",
    "authPrefix": "Bearer",
    "oauth": {
      "clientIdEnv": "QUICKBOOKS_CLIENT_ID",
      "clientSecretEnv": "QUICKBOOKS_CLIENT_SECRET",
      "tokenUrl": "https://oauth.platform.intuit.com/oauth2/v1/tokens/bearer",
      "grantType": "refresh_token"
    }
  },
  "google-sheets": {
    "baseUrl": "https://sheets.googleapis.com/v4",
    "keyEnv": "GOOGLE_SHEETS_TOKEN",
    "authHeader": "Authorization",
    "authPrefix": "Bearer",
    "nango": {
      "providerEnv": "NANGO_PROVIDER_CONFIG_KEY",
      "connectionIdEnv": "NANGO_CONNECTION_ID"
    }
  }
}
